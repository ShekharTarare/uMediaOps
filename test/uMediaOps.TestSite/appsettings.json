{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "02de31b5-60b5-4732-9eef-2c3fea5a9336",
        "SanitizeTinyMce": true,
        "Smtp": {
          "From": "uMediaOps@localhost",
          "Host": "localhost",
          "Port": 25,
          "SecureSocketOptions": "None",
          "Username": "",
          "Password": ""
        }
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true,
        "InstallUnattended": true,
        "UnattendedUserName": "admin@example.com",
        "UnattendedUserEmail": "admin@example.com",
        "UnattendedUserPassword": "ChangeMe123!"
      },
      "Security": {
        "AllowConcurrentLogins": false
      }
    }
  },
  "uMediaOps": {
    "BackupDirectory": "~/App_Data/uMediaOps/Backups",
    "BackupRetentionDays": 30
  }
}
